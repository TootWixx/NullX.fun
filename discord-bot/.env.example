# Copy this file to .env and fill in values (never commit .env).

# Discord — Bot → https://discord.com/developers/applications → Bot → Reset Token
DISCORD_BOT_TOKEN=

# Application ID (for slash commands). Optional but recommended.
DISCORD_APPLICATION_ID=

# Guild ID for instant slash commands (optional; omit for global registration).
DISCORD_GUILD_ID=

# Supabase — same project as the web app (Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
